      "parameters": {
        "jsCode": "const raw = $json.generated_content || '';\nlet parsed = { subject: 'Closing the loop', body: raw };\ntry {\n  const m = raw.match(/\\{[\\s\\S]*\\}/);\n  if (m) parsed = JSON.parse(m[0]);\n} catch(e) {}\nreturn [{ json: { ...$json, subject: parsed.subject, body: parsed.body } }];"
      }
