              "name": "user_prompt",
              "value": "={{ 'Write a soft-close email from ' + $('Client Config').item.json.sender_name + ' to ' + $json.full_name + ' at ' + $json.company + '. This is the last email in the sequence. Acknowledge timing may not be right. Leave door open for future. Format as JSON: { \"subject\": \"...\", \"body\": \"...\" }' }}"
            }
          ]
        }
      }
    },
